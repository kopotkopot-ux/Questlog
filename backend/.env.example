# Server
NODE_ENV=development
PORT=5000

# Database (MySQL Workbench 8.0)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=questlog

# JWT Authentication
JWT_SECRET=change_this_to_a_long_random_secret_key_min_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change_this_refresh_secret_key_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# Password Reset
RESET_TOKEN_EXPIRES_HOURS=1
FRONTEND_URL=http://localhost:5173

# Email (for password reset - optional in development)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=QuestLog <noreply@questlog.app>

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
